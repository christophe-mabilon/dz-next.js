# Site Configuration
NEXT_PUBLIC_SITE_URL=https://dzmaconnerie38.fr
NEXT_PUBLIC_SITE_NAME="DZ Maçonnerie & Terrassement"

# Google
NEXT_PUBLIC_GOOGLE_VERIFICATION_CODE=votre_code_google

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ============================================================================
# Envoi des emails des formulaires (contact + partenaires)
# ⚠️ Ceci est un MODÈLE versionné (dépôt public). NE JAMAIS y mettre le vrai
#    mot de passe : les vraies valeurs vont dans .env.local (jamais dans git).
# Sans ces variables, les formulaires répondent OK mais n'envoient rien (démo).
# ============================================================================

# --- Option A : Gmail (adresse @gmail.com) --------------------------------
# Nécessite un "mot de passe d'application" Google (2FA activée sur le compte) :
#   Compte Google > Sécurité > Validation en 2 étapes > Mots de passe d'application
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=dz.maconnerie38@gmail.com
SMTP_PASSWORD=mot_de_passe_application_google

# --- Option B : boîte OVH (@dzmaconnerie38.fr) ----------------------------
# SMTP_HOST=ssl0.ovh.net
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=contact@dzmaconnerie38.fr
# SMTP_PASSWORD=le_mot_de_passe_de_la_boite

# Destinataire des demandes (défaut = SMTP_USER) et expéditeur affiché
MAIL_TO=dz.maconnerie38@gmail.com
MAIL_FROM=dz.maconnerie38@gmail.com
# Copie cachée webmaster (optionnel) : reçoit une copie de chaque demande,
# invisible du destinataire principal. Laisser vide pour désactiver.
MAIL_BCC=

# Pour développement local
NODE_ENV=development

# Avis Google automatiques (scripts/fetch-reviews.mjs)
GOOGLE_MAPS_API_KEY=votre_cle_api
GOOGLE_PLACE_ID=votre_place_id
